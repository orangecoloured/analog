{
  "name": "analog",
  "version": "0.1.5",
  "description": "A minimal analytics tool to self-host.",
  "main": "index.js",
  "scripts": {
    "build": "vite build",
    "dev": "concurrently 'vite --host' 'DEBUG=ioredis:* npx tsx watch --env-file=.env.local src/services/server/index.ts'",
    "prepare": "husky install"
  },
  "keywords": [],
  "author": "RCKT",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@netlify/functions": "^5.2.0",
    "@netlify/vite-plugin": "^2.11.7",
    "@vercel/node": "^5.7.12",
    "ioredis": "^5.10.1",
    "mongodb": "^7.2.0",
    "pg": "^8.20.0",
    "toad-scheduler": "^3.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "uuid": "^14.0.0"
  },
  "engines": {
    "node": ">=22.x"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,mjs}": [
      "prettier --write",
      "eslint --fix",
      "git add"
    ],
    "*.{html,css}": [
      "prettier --write",
      "git add"
    ]
  }
}
